# Canton MCP Server — DevNet (ChainSafe)
MCP_SERVER_URL=https://mcp-dev1.01.chainsafe.dev

# When deployed in K8s, set to true so only system env vars are used
# IS_ISOLATED_ENVIRONMENT=true

# Authentication
JWT_SECRET=81b0a97a8e9360ad84f6f5e7dab083bd09f70003593faeca97535561e936afda

# Canton payments enabled
CANTON_ENABLED=true
CANTON_NETWORK=canton-devnet

# ============================================================================
# DEVNET: Canton Facilitator (payment coordination)
# ============================================================================
CANTON_FACILITATOR_URL=https://facilitator-dev1.01.chainsafe.dev

# Payee party on DevNet
CANTON_PAYEE_PARTY=damlcopilot-receiver::1220096316d4ea75c021d89123cfd2792cfeac80dfbf90bfbca21bcd8bf1bb40d84c

# Billing portal URL
BILLING_PORTAL_URL=https://billing-dev1.01.chainsafe.dev

# ============================================================================
# DEVNET: Canton JSON API v2 (ChainSafe DevNet)
# ============================================================================
# Ledger API - HTTP endpoint
CANTON_LEDGER_URL=https://canton-ledger-api-http-dev1.01.chainsafe.dev/api/json-api

# OAuth2 - Auth0 for ChainSafe DevNet
CANTON_OAUTH_TOKEN_URL=https://dev-2j3m40ajwym1zzaq.eu.auth0.com/oauth/token
CANTON_OAUTH_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
CANTON_OAUTH_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
# Get these from ChainSafe or your Auth0 account

# REQUIRED: OAuth2 audience — must match the ledger API URL
# Without this, Auth0 returns 403 "No audience parameter was provided"
CANTON_OAUTH_AUDIENCE=https://canton-ledger-api-dev1.01.chainsafe.dev

# Canton provider party (creates ChargeReceipts/CreditReceipts)
CANTON_PROVIDER_PARTY=damlcopilot-receiver::1220096316d4ea75c021d89123cfd2792cfeac80dfbf90bfbca21bcd8bf1bb40d84c

# Canton user ID — Auth0 M2M format: CLIENT_ID@clients
CANTON_USER_ID=YOUR_AUTH0_CLIENT_ID@clients

# DSO Party (DevNet global domain admin)
CANTON_DSO_PARTY=DSO::1220be58c29e65de40bf273be1dc2b266d43a9a002ea5b18955aeef7aac881bb471a

# Billing package ID (MCP.Billing templates)
BILLING_PACKAGE_ID=c88342c027d94cf705b1c92828855c3ed45eea04c077aae8e8ff6811c71a30cc

# ============================================================================
# DEVNET: Validator API (for party registration and scan-proxy)
# ============================================================================
# Token Standard API / Scan Proxy
TOKEN_STANDARD_URL=https://wallet-validator-dev1.01.chainsafe.dev/api/validator/v0/scan-proxy

# Validator Admin API (for external party registration during auth)
VALIDATOR_API_URL=https://wallet-validator-dev1.01.chainsafe.dev/api/validator
VALIDATOR_OAUTH_TOKEN_URL=https://dev-2j3m40ajwym1zzaq.eu.auth0.com/oauth/token
VALIDATOR_OAUTH_CLIENT_ID=YOUR_VALIDATOR_AUTH0_CLIENT_ID
VALIDATOR_OAUTH_CLIENT_SECRET=YOUR_VALIDATOR_AUTH0_CLIENT_SECRET
VALIDATOR_OAUTH_AUDIENCE=https://canton-ledger-api-dev1.01.chainsafe.dev

# ============================================================================
# On-chain billing configuration
# ============================================================================
BILLING_ENABLED=true
MIN_BALANCE_THRESHOLD=-2.0
FREE_TIER_CALLS=20

# API key for billing portal to create credits
BILLING_API_KEY=7d34e3a217b27e7857e51f102ac3f9a6caa46463a04a2d592b75690c0e02a6cd

# ============================================================================
# X402 Payments (EVM/USDC) — disabled for DevNet, Canton payments used instead
# ============================================================================
X402_ENABLED=false
# X402_PRICING_MODE=dynamic
# X402_MIN_PAYMENT=0.001
# X402_MAX_PAYMENT=10.0
# X402_VERIFICATION_TIMEOUT=30
# X402_SETTLEMENT_TIMEOUT=60
# X402_NETWORK=base-sepolia
# X402_TOKEN=USDC
# X402_WALLET_ADDRESS=
# X402_WALLET_PRIVATE_KEY=
# X402_INTERNAL_API_KEY=

# ============================================================================
# DCAP Performance Tracking (optional)
# ============================================================================
DCAP_ENABLED=false
# DCAP_MULTICAST_IP=
# DCAP_PORT=10191
# DCAP_SERVER_ID=canton-mcp-dev
# DCAP_SERVER_NAME=Canton MCP DevNet Server
# DCAP_DEFAULT_CALLER=unknown-client
# DCAP_DEFAULT_PAYER=0x0000000000000000000000000000000000000000

# ============================================================================
# DAML SDK & Canonical Docs
# ============================================================================
DAML_SDK_VERSION=3.4.0-snapshot.20251013.0

# Path to canonical DAML documentation directory
# MUST be set on remote — without this, semantic search returns 0 results
CANONICAL_DOCS_PATH=/app/docs

# ============================================================================
# LLM Configuration (optional)
# ============================================================================
# Anthropic API key (required if LLM enrichment or auth extraction is enabled)
# ANTHROPIC_API_KEY=sk-ant-api03-...

ENABLE_LLM_ENRICHMENT=false
ENABLE_LLM_AUTH_EXTRACTION=false
# LLM_ENRICHMENT_MODEL=claude-3-5-haiku-20241022
# LLM_ENRICHMENT_BATCH_SIZE=20
# LLM_ENRICHMENT_MAX_TOKENS=500
# LLM_AUTH_CONFIDENCE_THRESHOLD=0.7
