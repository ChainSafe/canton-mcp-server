# Canton MCP Server Configuration
# Copy this file to .env.canton and adjust values as needed

# ============================================================================
# MCP Server Configuration
# ============================================================================
MCP_SERVER_URL=http://localhost:7284

# When true, skips .env.canton file loading and uses only system env vars
# Use in production/K8s where env vars are injected externally
IS_ISOLATED_ENVIRONMENT=false

# ============================================================================
# Authentication (JWT for challenge-response auth)
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ============================================================================
# Canton Payment System
# ============================================================================
CANTON_ENABLED=true
CANTON_NETWORK=canton-devnet

# ============================================================================
# Canton Facilitator (payment coordination)
# ============================================================================
CANTON_FACILITATOR_URL=http://localhost:3001

# ============================================================================
# Canton Parties
# ============================================================================
# Payee party (receives tool payments from users)
CANTON_PAYEE_PARTY=your-party::1220...

# Provider party (creates ChargeReceipts/CreditReceipts on ledger)
# Usually the same as CANTON_PAYEE_PARTY
CANTON_PROVIDER_PARTY=your-party::1220...

# DSO party (global domain admin — used for AmuletRules lookups)
CANTON_DSO_PARTY=DSO::1220...

# ============================================================================
# Canton JSON API v2
# ============================================================================
CANTON_LEDGER_URL=http://localhost:3975

# ============================================================================
# OAuth2 Authentication (for Canton Ledger API)
# ============================================================================
# Token endpoint (Auth0, Keycloak, etc.)
CANTON_OAUTH_TOKEN_URL=http://localhost:8082/realms/AppProvider/protocol/openid-connect/token

# OAuth2 client credentials
CANTON_OAUTH_CLIENT_ID=your-client-id
CANTON_OAUTH_CLIENT_SECRET=your-client-secret

# REQUIRED: OAuth2 audience — must match the ledger API URL
# Without this, the OAuth token request will fail with 403
CANTON_OAUTH_AUDIENCE=http://localhost:3975

# Canton user ID — the service account user registered in Canton
# For Auth0: usually "CLIENT_ID@clients"
# For Keycloak: the user ID configured in Canton
CANTON_USER_ID=your-user-id

# ============================================================================
# On-Chain Billing (ChargeReceipt / CreditReceipt contracts)
# ============================================================================
# Daml package ID containing MCP.Billing templates
# Get this after deploying the billing DAR to your Canton participant
BILLING_PACKAGE_ID=your-billing-package-id

# Enable on-chain billing (ChargeReceipt creation after tool calls)
BILLING_ENABLED=true

# Minimum balance before blocking tool execution
# Negative value = users can owe up to this amount before being cut off
# Example: -2.0 means users get ~20 free calls at $0.10 each
MIN_BALANCE_THRESHOLD=-2.0

# API key for billing portal to create CreditReceipts (top-ups)
# Generate with: openssl rand -hex 32
BILLING_API_KEY=

# Billing portal URL (shown to users when balance is low)
BILLING_PORTAL_URL=http://localhost:3050

# Number of free tool calls before payment is required
FREE_TIER_CALLS=20

# ============================================================================
# Validator API (for external party registration during auth)
# ============================================================================
# The MCP server auto-registers external parties on the Canton synchronizer
# during challenge-response auth. This requires Validator Admin API access.
VALIDATOR_API_URL=http://localhost:3903/api/validator
VALIDATOR_OAUTH_TOKEN_URL=http://localhost:8082/realms/AppProvider/protocol/openid-connect/token
VALIDATOR_OAUTH_CLIENT_ID=your-validator-client-id
VALIDATOR_OAUTH_CLIENT_SECRET=your-validator-client-secret
VALIDATOR_OAUTH_AUDIENCE=http://localhost:3975

# Token Standard API / Scan Proxy (for balance lookups and AmuletRules)
TOKEN_STANDARD_URL=http://localhost:3903/api/validator/v0/scan-proxy

# ============================================================================
# Canton 3.4 gRPC Flow (external party onboarding via Participant Admin API)
# ============================================================================
# On devnet, Validator API /v0/admin/external-party/* needs validator operator JWT,
# which M2M client_credentials tokens are NOT. Use Participant Admin gRPC instead.
# Set to true on devnet; false (or omit) on localnet where Validator API works.
USE_CANTON_34_FLOW=false
# Participant Admin gRPC endpoint (devnet: canton-ledger-admin-api-grpc-dev1.chainsafe.dev:443)
CANTON_PARTICIPANT_ADMIN_API=
# Your participant and domain IDs (get from ChainSafe for devnet)
PARTICIPANT_ID=
DOMAIN_ID=

# ============================================================================
# Development Settings
# ============================================================================
# Enable hot-reload for resource files (development only)
CANTON_HOT_RELOAD=false

# ============================================================================
# DCAP (Performance Tracking) - optional
# ============================================================================
DCAP_ENABLED=false
# DCAP_MULTICAST_IP=159.89.110.236
# DCAP_PORT=10191
# DCAP_SERVER_ID=canton-mcp
# DCAP_SERVER_NAME=Canton MCP Server
# DCAP_DEFAULT_CALLER=unknown-client
# DCAP_DEFAULT_PAYER=0x0000000000000000000000000000000000000000

# ============================================================================
# x402 Payment Configuration (EVM/USDC) - optional, separate from Canton
# ============================================================================
X402_ENABLED=false
# X402_WALLET_ADDRESS=
# X402_WALLET_PRIVATE_KEY=
# X402_NETWORK=base-sepolia
# X402_TOKEN=USDC
# X402_INTERNAL_API_KEY=
# X402_PRICING_MODE=dynamic
# X402_MIN_PAYMENT=0.001
# X402_MAX_PAYMENT=10.0
# X402_VERIFICATION_TIMEOUT=30
# X402_SETTLEMENT_TIMEOUT=60

# ============================================================================
# DAML SDK & Canonical Docs
# ============================================================================
# DAML SDK version (used by tools that reference SDK APIs)
DAML_SDK_VERSION=3.4.0-snapshot.20251013.0

# Path to canonical DAML documentation directory (for semantic search in daml_reason tool)
# If not set, defaults to ../../canonical-daml-docs (relative to server root)
CANONICAL_DOCS_PATH=../../canonical-daml-docs

# ============================================================================
# Embedding Device (ChromaDB)
# ============================================================================
# "cpu" (default): ONNX MiniLM embeddings — no extra deps needed
# "cuda": SentenceTransformers + PyTorch GPU — ~55x faster on NVIDIA GPUs
# WARNING: Switching between cpu/cuda triggers automatic re-indexing
# because ONNX and SentenceTransformer produce different embeddings
EMBEDDING_DEVICE=cpu

# ============================================================================
# LLM Configuration - optional
# ============================================================================
# Anthropic API key (required if ENABLE_LLM_ENRICHMENT or ENABLE_LLM_AUTH_EXTRACTION is true)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Enable LLM enrichment for tool descriptions
ENABLE_LLM_ENRICHMENT=false

# Use LLM for authorization extraction from user messages (falls back to regex if disabled)
ENABLE_LLM_AUTH_EXTRACTION=false

# LLM enrichment settings
# LLM_ENRICHMENT_MODEL=claude-3-5-haiku-20241022
# LLM_ENRICHMENT_BATCH_SIZE=20
# LLM_ENRICHMENT_MAX_TOKENS=500

# Confidence threshold (0-1) for LLM auth extraction
# LLM_AUTH_CONFIDENCE_THRESHOLD=0.7
